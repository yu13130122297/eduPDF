# 教育数据集课堂行为分类配置文件
# 使用 true/false 来启用或禁用各个分类

# 分类1：学生发言 (405, 31.5%)
STUDENT_SPEECH_ENABLED=true

# 分类2：学生讨论 (94, 7.3%)
STUDENT_DISCUSSION_ENABLED=true

# 分类3：技术操作 (3, 0.2%)
TECH_OPERATION_ENABLED=true

# 分类4：教师反馈 (48, 3.7%)
TEACHER_FEEDBACK_ENABLED=true

# 分类5：教师巡视 (151, 11.7%)
TEACHER_PATROL_ENABLED=true

# 分类6：教师指令 (35, 2.7%)
TEACHER_INSTRUCTION_ENABLED=true

# 分类7：教师提问 (122, 9.5%)
TEACHER_QUESTION_ENABLED=true

# 分类8：教师板书 (58, 4.5%)
TEACHER_WRITING_ENABLED=true

# 分类9：教师讲授 (265, 20.6%)
TEACHER_LECTURE_ENABLED=true

# 分类10：课堂沉寂 (105, 8.2%)
CLASSROOM_SILENCE_ENABLED=true

# 全局配置
ALL_CATEGORIES_ENABLED=true
DEBUG_MODE=false
LOG_LEVEL=INFO